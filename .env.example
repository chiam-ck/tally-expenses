# ── Postgres (lives on tech-vm; reach it over the tailnet, NOT localhost) ──────
# psycopg accepts a plain postgresql:// DSN. A SQLAlchemy-style
# postgresql+asyncpg:// scheme is also tolerated (the app strips the +driver).
DATABASE_URL=postgresql://expenses:CHANGE_ME@db-host.<tailnet>.ts.net:5432/expenses

TZ=Asia/Singapore

# ── LLM parse endpoint — ANY OpenAI-compatible chat-completions provider ──────
# The "LITELLM_" names are historical; this works with any provider that exposes
# an OpenAI-style POST /v1/chat/completions (temperature, response_format,
# messages). Examples:
#   OpenAI        https://api.openai.com/v1/chat/completions          (model: gpt-4o-mini)
#   OpenRouter    https://openrouter.ai/api/v1/chat/completions       (model: openai/gpt-4o-mini)
#   Groq          https://api.groq.com/openai/v1/chat/completions     (model: llama-3.3-70b-versatile)
#   Together      https://api.together.xyz/v1/chat/completions
#   LiteLLM proxy http://<host>:4000/v1/chat/completions
#   Ollama (local, no key) http://<host>:11434/v1/chat/completions    (model: llama3.1)
#   vLLM (self-hosted)     http://<host>:8000/v1/chat/completions
# If the endpoint is unreachable or returns junk, parsing falls back to a local
# regex (logging never blocks on the LLM). Leave LITELLM_KEY blank to skip the
# LLM entirely and always use the regex parser.
LITELLM_URL=http://localhost:4000/v1/chat/completions
LITELLM_KEY=sk-...
LITELLM_MODEL=openai/gpt-4o-mini

# ── Weekly digest via Resend (the job no-ops if RESEND_API_KEY is unset) ──────
RESEND_API_KEY=re_...
DIGEST_FROM=expenses@your-verified-domain.com   # must be a Resend-verified sender
DIGEST_TO=you@example.com

# ── Branding (optional; shown in the topbar, login, and dashboard headline) ──
APP_NAME=Tally
APP_TAGLINE=Your money, counted

# ── Auth (single-user login gate) ────────────────────────────────────────────
AUTH_USERNAME=admin
AUTH_PASSWORD=change-me
# Signs the session cookie; changing it (or the password) invalidates sessions.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# ── API key for programmatic /api/* access (external agents / MCP server) ─────
# Lets non-browser clients reach /api/* without the login cookie. Send it as
# `Authorization: Bearer <key>` or `X-API-Key: <key>`. Leave blank to disable
# (then only the browser session cookie can reach the API).
# Generate: python -c "import secrets; print('tally_sk_' + secrets.token_urlsafe(32))"
API_KEY=

# ── Token guarding the MCP endpoint (:9000/mcp) itself, used by the mcp service ─
# Defence-in-depth on top of the tailnet: agents must send it as
# `Authorization: Bearer <token>` to reach the MCP server. Distinct from API_KEY
# (which the MCP server uses internally to reach the app). Blank = endpoint open.
# Generate: python -c "import secrets; print('tmcp_' + secrets.token_urlsafe(32))"
MCP_AUTH_TOKEN=
